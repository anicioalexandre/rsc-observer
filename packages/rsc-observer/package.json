{
  "name": "rsc-observer",
  "version": "0.0.0",
  "description": "Dev-time observability for React Server Components in Next.js App Router",
  "type": "module",
  "license": "MIT",
  "author": "Alexandre Anicio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anicioalexandre/rsc-observer.git",
    "directory": "packages/rsc-observer"
  },
  "homepage": "https://github.com/anicioalexandre/rsc-observer#readme",
  "bugs": "https://github.com/anicioalexandre/rsc-observer/issues",
  "keywords": ["react", "rsc", "server-components", "nextjs", "devtools"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./instrumentation": {
      "types": "./dist/instrumentation.d.ts",
      "import": "./dist/instrumentation.js",
      "require": "./dist/instrumentation.cjs"
    },
    "./instrument-server": {
      "types": "./dist/instrument-server.d.ts",
      "import": "./dist/instrument-server.js",
      "require": "./dist/instrument-server.cjs"
    },
    "./instrument-client": {
      "types": "./dist/instrument-client.d.ts",
      "import": "./dist/instrument-client.js",
      "require": "./dist/instrument-client.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "bin": {
    "rsc-observer": "./dist/cli.cjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=15.0.0"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/ws": "^8.5.13",
    "tsdown": "^0.10.0",
    "typescript": "5.9.2"
  }
}
